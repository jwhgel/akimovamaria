import time
import sys

def measureTime(func, vec):
    start = time.time()
    func(vec)
    end = time.time()
    return (end - start) * 1000

def getUserInput():
    while True:
        try:
            value = int(input("Enter the size of the array: "))
            if value <= 0:
                print("Invalid input! Please enter a positive number: ")
                continue
            return value
        except ValueError:
            print("Invalid input! Please enter a positive number: ")

def createArray(size):
    vec = []
    for i in range(size):
        vec.append(i)
    return vec

def removeElements(vec):
    while len(vec) > 0:
        vec.pop()

def main():
    size = getUserInput()
    numbers = createArray(size)
    initial_memory_bytes = sys.getsizeof(numbers)
    timeTaken = measureTime(removeElements, numbers)
    final_memory_bytes = sys.getsizeof(numbers)
    
    print(f"\n--- Результаты для массива из {size} элементов ---")
    print(f"Time taken to remove elements: {timeTaken:.4f} ms")
    print(f"Initial memory size (allocated): {initial_memory_bytes / (1024 * 1024):.4f} MB")
    print(f"Final memory size (after pop): {final_memory_bytes / (1024 * 1024):.4f} MB")

if __name__ == "__main__":
    main()


